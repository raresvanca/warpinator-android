    <!-- ==================== Transfer States and Details ==================== -->

    <!--
    Indicates the total number of files involved in a transfer.
    Example: "1 file", "24 files"
    -->
    <plurals name="transfer_files_count">
        <item quantity="one">%1$d file</item>
        <item quantity="other">%1$d files</item>
    </plurals>

    <!--
    Format used to show progress of a file transfer.
    %1$s is the amount of data already transferred (e.g., "5.2 MB").
    %2$s is the total size of the transfer (e.g., "10 MB").

    Example: "5.2 MB / 10 MB"

    Translators: You may change the separator (" / ") to match your locale's
    standard for representing parts of a whole.
    -->
    <string name="transfer_short_status_fmt">%1$s / %2$s</string>
    <!--
    Format used to show progress of a file transfer and remaining time.
    %1$s is the amount of data already transferred (e.g., "5.2 MB").
    %2$s is the total size of the transfer (e.g., "10 MB").
    %3$s is the current speed (e.g., "10kB/s").
    %4$s is the remaining time label (e.g., "5m 30s remaining").

    Example: "5.2 MB / 10 MB (10kB/s, 5m 30s remaining)"

    Translators: You may change the separator (" / ") to match your locale's
    standard for representing parts of a whole.
    -->
    <string name="transfer_long_status_fmt">%1$s / %2$s (%3$s, %4$s)</string>

    <!--
    Format used to represent the speed of a file transfer in a data size over
    one second.
    %1$s is the size (e.g., "15kB").

    Example: "15kB/s"
    -->
    <string name="transfer_speed_fmt">%1$s/s</string>

    <!--  A remaining time status that did not calculate yet or is indefinite  -->
    <string name="time_indefinite">calculating…</string>

    <!--  A remaining time status for when the time is estimated at more than 24h  -->
    <string name="time_over_day">more than a day remaining</string>

    <!--  A remaining time status for when the time is estimated at 5 seconds or less  -->
    <string name="time_few_seconds_remaining">a few seconds remaining</string>

    <!--
    Format used to represent remaining seconds in a file transfer.
    %1$d is the number of seconds remaining (e.g., "5").

    Example: "5s remaining"

    Translators: You may change the use of the "s" abbreviation and use full words if the
    locale is not accommodated with "s"
    -->
    <plurals name="time_seconds_remaining">
        <item quantity="one">%1$ds remaining</item>
        <item quantity="other">%1$ds remaining</item>
    </plurals>

    <!--
    Format used to represent remaining time in a file transfer in a BIG UNIT SMALLER UNIT
    format.
    %1$s is the big formatted unit (e.g., "5h", "20m").
    %2$s is the small formatted unit (e.g., "30m", "5s").

    Example: "30m 20s remaining", "5h 30m remaining"
    -->
    <string name="time_details_remaining_fmt">%1$s %2$s remaining</string>

    <!--  Format for hours  -->
    <plurals name="duration_hours_short">
        <item quantity="other">%1$dh</item>
    </plurals>
    <!--  Format for minutes  -->
    <plurals name="duration_minutes_short">
        <item quantity="other">%1$dm</item>
    </plurals>
    <!--  Format for seconds  -->
    <plurals name="duration_seconds_short">
        <item quantity="other">%1$ds</item>
    </plurals>

